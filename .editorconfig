root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.cs]
indent_size = 4
# Convenções básicas C# / Unity
dotnet_sort_system_directives_first = true
csharp_new_line_before_open_brace = all

[*.{py}]
indent_size = 4
max_line_length = 100

[*.{json,yml,yaml,asmdef}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
